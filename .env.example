# HubWatch — Local Environment Template
#
# This file is SAFE to commit. It is only a template.
# Copy this file to `.env` and fill in your real values.
# The `.env` file is git-ignored and should NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your actual values

# ─── Server Configuration ──────────────────────────────────────────────────────

# Local IP address of your home server (e.g. 192.168.2.1)
SERVER_IP=YOUR_SERVER_IP_HERE

# Port where the JSON status script is running
SERVER_PORT=8000

# Full path to the status JSON file served by the script
STATUS_ENDPOINT=/hub_status.json

# ─── App Behaviour ─────────────────────────────────────────────────────────────

# How often the app polls the server in milliseconds (default: 30000 = 30s)
POLL_INTERVAL_MS=30000

# Storage usage % that triggers emergency alert + vibration (default: 90)
STORAGE_ALERT_THRESHOLD=90
